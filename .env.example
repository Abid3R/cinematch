# =============================================================================
# CineMatch ‚Äî Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in your own keys.
# Never commit `.env.local` ‚Äî it is in `.gitignore`.
# =============================================================================

# -----------------------------------------------------------------------------
# TMDB (The Movie Database) ‚Äî REQUIRED
# Get a free API key: https://www.themoviedb.org/settings/api
# -----------------------------------------------------------------------------
# v3 API key (used as `api_key` query param). Server-side only.
TMDB_API_KEY=your_tmdb_v3_api_key_here

# v4 Read Access Token (Bearer). Optional fallback; preferred for v4 endpoints.
TMDB_ACCESS_TOKEN=your_tmdb_v4_read_access_token_here

# Public TMDB image base ‚Äî safe to expose.
NEXT_PUBLIC_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p

# -----------------------------------------------------------------------------
# OpenAI ‚Äî OPTIONAL (Future natural-language recommendations)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=CineMatch
